#footer
  background: color-footer-background
  padding: 50px 0
  border-top: 6px solid color-sdv-darkgrass
  box-shadow: inset 0 4px 0 color-sdv-gold
  color: color-sdv-cream
  font-family: font-pixel
  a
    color: color-sdv-gold
    text-decoration: none
    &:hover
      text-decoration: underline
      color: color-sdv-orange

#footer-info
  line-height: line-height
  font-size: 0.85em
@media mq-mobile
  #mobile-nav
    position: absolute
    top: 0
    left: 0
    width: mobile-nav-width
    height: 100%
    background: color-sdv-dirt
    border-right: 6px solid color-sdv-darkgrass
    box-shadow: 6px 0 0 color-sdv-wood

@media mq-mobile
  .mobile-nav-link
    display: block
    color: color-sdv-cream
    text-decoration: none
    padding: 15px 20px
    font-weight: bold
    font-family: font-pixel
    border-bottom: 2px solid color-sdv-darkgrass
    &:hover
      color: color-sdv-gold
      background: color-sdv-darkgrass

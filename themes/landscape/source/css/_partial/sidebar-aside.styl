#sidebar
  @media mq-normal
    column(sidebar-column)

.widget-wrap
  margin: block-margin 0

.widget-title
  @extend $block-caption

.widget
  color: color-sidebar-text
  background: color-widget-background
  border: 4px solid color-sdv-dirt
  box-shadow:
    3px 3px 0 color-sdv-wood,
    inset 0 0 0 2px color-sdv-gold
  padding: 15px
  border-radius: 0
  image-rendering: pixelated
  a
    color: color-sdv-darkgrass
    text-decoration: none
    &:hover
      color: color-sdv-orange
  ul, ol, dl
    ul, ol, dl
      margin-left: 15px
      list-style: disc
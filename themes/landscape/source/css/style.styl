@import "nib"
@import "_variables"
@import "_util/mixin"
@import "_util/grid"

global-reset()

input, button
  margin: 0
  padding: 0
  &::-moz-focus-inner
    border: 0
    padding: 0

html, body, #container
  height: 100%

body
  background: color-background
  font: font-size font-sans
  -webkit-text-size-adjust: 100%
  image-rendering: pixelated
  // Pixel grass pattern background
  background-image:
    linear-gradient(180deg, rgba(92,148,252,0.15) 0%, rgba(200,230,201,0.4) 40%, rgba(106,190,48,0.2) 100%),
    url("data:image/svg+xml,%3Csvg width='16' height='16' viewBox='0 0 16 16' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 0h16v16H0z' fill='%23C8E6C9'/%3E%3Cpath d='M0 14h16v2H0z' fill='%236ABE30' opacity='0.3'/%3E%3Cpath d='M2 0h2v16H2z' fill='%236ABE30' opacity='0.15'/%3E%3C/svg%3E")
  background-attachment: fixed

.outer
  clearfix()
  max-width: (column-width + gutter-width) * columns + gutter-width
  margin: 0 auto
  padding: 0 gutter-width

.inner
  column(columns)

.left, .alignleft
  float: left

.right, .alignright
  float: right

.clear
  clear: both

#container
  position: relative

.mobile-nav-on
  overflow: hidden

#wrap
  height: 100%
  width: 100%
  position: absolute
  top: 0
  left: 0
  transition: 0.2s ease-out
  z-index: 1
  background: color-background
  .mobile-nav-on &
    left: mobile-nav-width

if sidebar and sidebar isnt bottom
  #main
    @media mq-normal
      column(main-column)

if sidebar is left
  @media mq-normal
    #main
      float: right

@import "_extend"
@import "_partial/header"
@import "_partial/article"
@import "_partial/comment"
@import "_partial/archive"
@import "_partial/footer"
@import "_partial/highlight"
@import "_partial/mobile"

if sidebar
  @import "_partial/sidebar"

// ========== Stardew Valley Extra Pixel Decorations ==========

// Pixel selection style
::selection
  background: color-sdv-gold
  color: color-default

// Pixel scrollbar
::-webkit-scrollbar
  width: 12px
::-webkit-scrollbar-track
  background: color-sdv-cream
  border-left: 3px solid color-sdv-dirt
::-webkit-scrollbar-thumb
  background: color-sdv-dirt
  border: 2px solid color-sdv-cream
  &:hover
    background: color-sdv-darkgrass

// Pixel-style links hover effect
.article-entry a
  color: color-sdv-darkgrass
  text-decoration: none
  border-bottom: 2px dashed color-sdv-grass
  transition: all 0.2s
  &:hover
    color: color-sdv-orange
    border-bottom-color: color-sdv-orange

// Stardew-style blockquote
.article-entry blockquote
  font-family: font-serif
  margin: line-height 20px
  text-align: center
  background: color-widget-background
  border-left: 6px solid color-sdv-gold
  border-right: 6px solid color-sdv-gold
  border-radius: 0
  padding: 15px 20px
  box-shadow: 3px 3px 0 color-sdv-dirt

// Stardew-style tables
.article-entry table
  th
    border-bottom: 4px solid color-sdv-darkgrass
    background: color-sdv-dirt
    color: #fff
    font-family: font-pixel
  td
    border-bottom: 2px dashed color-sdv-dirt

// Pixel flower decorations at bottom of articles
.article-inner::after
  content: "🌻 🌿 🌻"
  display: block
  text-align: center
  padding: 10px
  font-size: 1.2em
  opacity: 0.6

// Tag links pixel style
.article-tag-list-link
  color: color-sdv-darkgrass
  font-family: font-pixel
  font-size: 0.9em
  &:hover
    color: color-sdv-orange

// Stardew date capsule style
.article-date
  font-family: font-pixel
  color: color-sdv-orange
  font-size: 0.85em
  background: color-sdv-cream
  padding: 2px 10px
  border: 2px solid color-sdv-dirt

// Category pill
.article-category
  .article-category-link
    font-family: font-pixel
    color: color-sdv-darkgrass
    background: color-sdv-grass
    padding: 2px 10px
    border: 2px solid color-sdv-darkgrass
    &:hover
      background: color-sdv-orange
      color: #fff

// Header nav links pixel hover
.main-nav-link
  font-family: font-pixel
  letter-spacing: 2px
  &:hover
    background: rgba(0,0,0,0.2)
    border-radius: 0

// Stardew decorative separator for footer
#footer-info
  position: relative
  padding-top: 15px
  &::before
    content: "🌾 🌾 🌾"
    display: block
    text-align: center
    margin-bottom: 15px
    font-size: 1.2em